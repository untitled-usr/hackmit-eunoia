# Future FastAPI middle layer
MID_AUTH_PORT=19000
MID_AUTH_HOST=0.0.0.0
MID_AUTH_LOG_LEVEL=info
MID_AUTH_ENABLE_HTTPS=false
# MID_AUTH_TLS_CERTFILE=/path/to/tls.crt
# MID_AUTH_TLS_KEYFILE=/path/to/tls.key
MID_AUTH_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/mid_auth
MID_AUTH_SESSION_COOKIE_NAME=mid_auth_session
MID_AUTH_SESSION_TTL_SECONDS=1209600
MID_AUTH_SESSION_COOKIE_SECURE=false
MID_AUTH_SESSION_COOKIE_SAMESITE=lax
MID_AUTH_SESSION_COOKIE_PATH=/

# Provisioning (OpenWebUI, VoceChat, Memos). Base URLs match devstack apps + env/templates:
# open-webui.env.example PORT=7920, memos.env.example MEMOS_PORT=7921,
# vocechat.env.example VOCECHAT_SERVER_PORT=7922 (HTTP API under /api).
# Tests use MID_AUTH_PROVISION_USE_STUB=true to skip HTTP.
# MID_AUTH_PROVISION_USE_STUB=false
MID_AUTH_OPEN_WEBUI_BASE_URL=http://127.0.0.1:7920
MID_AUTH_VOCECHAT_BASE_URL=http://127.0.0.1:7922/api
MID_AUTH_MEMOS_BASE_URL=http://127.0.0.1:7921
# Timeouts: provisioning (register) vs downstream APIs (/me/posts, /me/conversations)
# MID_AUTH_PROVISION_HTTP_TIMEOUT_SECONDS=30
# MID_AUTH_MEMOS_HTTP_TIMEOUT_SECONDS=30
# MID_AUTH_VOCECHAT_HTTP_TIMEOUT_SECONDS=30
# OpenWebUI (module-07 /me/ai/chats)
# MID_AUTH_OPENWEBUI_HTTP_TIMEOUT_SECONDS=120
# MID_AUTH_OPENWEBUI_DEFAULT_MODEL_ID=gpt-4o-mini
# MID_AUTH_DOWNSTREAM_ACTING_UID_HEADER=X-Acting-Uid
# Optional: admin acting UIDs for best-effort cleanup on failed register
# MID_AUTH_OPEN_WEBUI_ADMIN_ACTING_UID=
# MID_AUTH_VOCECHAT_ADMIN_ACTING_UID=
# MID_AUTH_MEMOS_ADMIN_ACTING_UID=

# Reserved for future auth aggregation.
# AUTH_PROVIDER=oidc
# AUTH_ISSUER=
# AUTH_CLIENT_ID=
# AUTH_CLIENT_SECRET=
