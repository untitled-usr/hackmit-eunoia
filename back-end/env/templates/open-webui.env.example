# Open WebUI backend runtime env
PORT=7920

# Keep state outside source tree.
DATA_DIR=/srv/devstack/state/open-webui/data
DATABASE_URL=sqlite:////srv/devstack/state/open-webui/data/webui.db

# In dev, always trust env values over DB-persisted config.
ENABLE_PERSISTENT_CONFIG=False

# Align with reverse proxy and local FE dev origin.
# 整行加引号，避免 source .env 时分号被 shell 当成命令分隔符
CORS_ALLOW_ORIGIN='http://localhost:7923;http://127.0.0.1:7923;http://owui.dev.local'
FORWARDED_ALLOW_IPS=127.0.0.1

# Set a stable key before production-like testing.
WEBUI_SECRET_KEY=change-this-before-prod
